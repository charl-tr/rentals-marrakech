# Template des variables d'environnement
# Copier en .env.local et remplir les valeurs (.env.local est gitignoré).
# Les mêmes valeurs doivent être configurées sur Vercel (Production + Preview).

# ─── Supabase ─────────────────────────────────────────────────
# Dashboard Project > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ⚠️ Service role — JAMAIS exposer côté client. Utilisé uniquement par les scripts de seed et les server components admin.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Site URL ─────────────────────────────────────────────────
# URL publique du site (utilisée pour canonicals SEO et liens dans les emails).
# En local : http://localhost:3000
# En prod  : https://rentals-marrakech.vercel.app (ou domaine custom)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Resend (email outbound) ──────────────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@example.com
RESEND_FROM_NAME=Marrakech Realty

# Garde-fou : redirige tous les emails sortants vers cette adresse en dev/preview.
# À laisser vide ou supprimer en production une fois le domaine Resend vérifié.
DEV_EMAIL_OVERRIDE=charles.terrier.7@gmail.com

# ─── Sentry (optionnel — error tracking) ──────────────────────
# Si non défini, le sourcemap upload est désactivé au build (cf. next.config.ts).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
